<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/itemContacto"
    android:layout_width="match_parent"
    android:layout_height="78dp"
    android:background="@drawable/bg_contact_item"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="10dp">

    <ImageView
        android:id="@+id/imgItemContacto"
        android:layout_width="54dp"
        android:layout_height="54dp"
        android:background="@drawable/bg_image_circle"
        android:contentDescription="Imagen contacto"
        android:padding="10dp"
        android:scaleType="centerCrop"
        android:src="@android:drawable/ic_menu_camera" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginLeft="12dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtItemNombre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:text="Nombre contacto"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtItemTelefono"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:singleLine="true"
            android:text="9999-9999"
            android:textColor="@color/accent_green"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtItemPais"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:singleLine="true"
            android:text="Honduras (504)"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

    </LinearLayout>

</LinearLayout>